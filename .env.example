# ── Copy to .env and fill in real values ──────────────────────────────────────
# Never commit .env to version control.

# App
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=true
SECRET_KEY=changeme-at-least-32-characters-long!!

# Database
DATABASE_URL=postgresql+asyncpg://avengine:avengine@localhost:5432/avengine

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# TwelveLabs
TWELVELABS_API_KEY=...
TWELVELABS_INDEX_ID=...

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=avengine-output
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Proxy (residential rotation)
PROXY_ENDPOINT=proxy.provider.com:8080
PROXY_USERNAME=user
PROXY_PASSWORD=pass

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=video_embeddings

# Observability
SENTRY_DSN=
OTLP_ENDPOINT=http://localhost:4317
ENABLE_TRACING=false

VIDEO_OUTPUT_DIR=
